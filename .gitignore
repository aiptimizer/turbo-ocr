.DS_Store

# Layout detection model (~124 MB) — fetched on demand via
# scripts/export_pp_doclayoutv3.py
models/layout/

# Non-default language bundles — fetched at container start by
# scripts/entrypoint.sh when OCR_LANG=<lang> is set. Only Latin ships in
# the repo as flat-layout models/{det,rec,cls}.onnx + keys.txt; every
# other language is pulled on demand from the pinned PP-OCRv5 ONNX mirror.
models/rec/

# fastpdf2png binaries — auto-installed by scripts/install_fastpdf2png.sh
bin/fastpdf2png
bin/libpdfium.so
quantization/PaddleOCR/
quantization/pretrained/
quantization/output*/
quantization/.venv*/

# Benchmark outputs (overwritten on every run)
tests/benchmark/LATEST.md
tests/benchmark/LATEST.json
tests/benchmark/stress_*.json
tests/benchmark/PER_DOCUMENT.md
tests/benchmark/PER_DOCUMENT.json

# WIP — Python bindings and CLI (separate branch)
python/
src/cli/

# Layout-overlay debug images (rendered ad hoc by tests/draw_layout.py)
layout_overlay*.png

# Benchmark outputs
vlm_result_*.json
